# ============================================================
# GramCare AI — Environment Variables Template
# ============================================================
# Copy this file to the appropriate .env location and fill in values.
#
# Backend Service: ./apps/backend_service/.env
# ============================================================

# --- DATABASE ---
# Local dev: sqlite:///./gramcare_local.db
# Docker/Prod: postgresql://gramcare_user:securepassword123@postgres_db:5432/gramcare_db
DATABASE_URL=sqlite:///./gramcare_local.db

# --- JWT AUTHENTICATION ---
# Generate a strong random key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# Token expiry in minutes (default: 7 days = 10080)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- GOOGLE GEMINI AI ---
# Required for: AI Triage, Symptom Analysis, OCR
# Get free key: https://aistudio.google.com/
# Without this key, the AI module returns mock/fallback responses.
GEMINI_API_KEY=

# --- RAZORPAY PAYMENT GATEWAY ---
# Required for: Telehealth consultation payments
# Get test keys: https://dashboard.razorpay.com/
# Without these keys, payments use a mock mode (no real charges).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- CORS ---
# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001,http://localhost:80

# --- NODE.JS SIGNALING SERVER ---
# URL of the Socket.io realtime engine (WebRTC signaling, vitals, SOS)
NODE_SIGNALING_URL=http://localhost:4000

# ============================================================
# Frontend Apps (set via Docker env or .env.local)
# ============================================================
# Patient React App (Vite):
#   VITE_API_URL=http://localhost:8000
#   VITE_WS_URL=http://localhost:4000
#
# Doctor Portal (Next.js):
#   NEXT_PUBLIC_API_URL=http://localhost:8000
#   NEXT_PUBLIC_WS_URL=http://localhost:4000
#
# Pharmacy Portal (Next.js):
#   NEXT_PUBLIC_API_URL=http://localhost:8000
